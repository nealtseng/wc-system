# LLM narrative — NVIDIA NIM (nvapi-…) or DeepSeek API key
# NVIDIA NIM: key from https://build.nvidia.com — auto-uses integrate.api.nvidia.com
DEEPSEEK_API_KEY=your_api_key_here
# Optional overrides (auto-detected from key prefix if omitted)
# LLM_API_KEY=
# LLM_BASE_URL=https://integrate.api.nvidia.com/v1
# LLM_MODEL=meta/llama-3.1-70b-instruct

AIVEN_DB_URL=postgresql://user:pass@host:port/db?sslmode=require
# Optional: API-Football for alternative live scores (100 req/day; worldcup26 CDN is default)
API_FOOTBALL_KEY=your_api_football_key_here
# The Odds API — h2h odds for /api/signals (500 req/month free tier)
# Sport key: soccer_fifa_world_cup
THE_ODDS_API_KEY=your_odds_api_key_here
# Optional: override FIFA/SoFIFA player CSV (default: SolideSpoke GitHub mirror)
FIFA_CSV_URL=
# Optional: Football Manager 2026 player exports (FM26PlayerExport plugin, semicolon CSV)
# Per-team files: data/fm/FRA.csv, BRA.csv, … (filename = catalog team ID)
# FM_CSV_DIR=data/fm
# Optional: single master export filtered by Nat column when no per-team file exists
# Defaults to data/fm/players.csv when that file exists
# FM_CSV_FILE=data/fm/players.csv
BACKEND_PORT=8080
POSTGRES_DB=wcdb
POSTGRES_USER=wcuser
POSTGRES_PASSWORD=wcpass
POSTGRES_PORT=5432
